        },
        {
          "index": 2,
          "text": "Nhập tên đăng nhập và số điện thoại đăng ký sau đó bấm “Tiếp tục”",
          "image": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.2.png"
        },
        {
          "index": 3,
          "text": "Nhập mã OTP được gửi về tin nhắn SMS, sau đó bấm Tiếp tục",
          "image": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.3.png"
        },
        {
          "index": 4,
          "text": "Xác thực khuôn mặt theo yêu cầu. Sau khi hoàn thành Ipay sẽ gửi mật khẩu mới về tin nhắn (SMS). Bấm đăng nhập Ipay để tiếp tục",
          "image": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.4.png"
        },
        {
          "index": 5,
          "text": "Nhập mật khẩu theo yêu cầu.\nMật khẩu hiện tại: Nhập theo mật khẩu được gửi về tin nhắn (SMS)\nMật khẩu mới: Là mật khẩu mà khách hàng cần đổi\nBấm Tiếp tục",
          "image": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.5.png"
        },
        {
          "index": 6,
          "text": "Thực hiện quét khuôn mặt để xác nhận đổi mật khẩu thành công",
          "image": "https://raw.githubusercontent.com/giadinhbanker/anh-super-app-bac-phu-tho/main/1.6.png"
        }
      ]
